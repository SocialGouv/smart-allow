// Minimal snippet to wire smart-allow into your own project's devcontainer.
// Merge the keys below into your existing .devcontainer/devcontainer.json.
//
// Prerequisites on the HOST (once):
//   - Ollama installed and listening on 0.0.0.0 (run ./install-host-ollama.sh from smart-allow).
//
// The installer downloads a prebuilt Go binary from GitHub releases; no Go/Python
// toolchain is required at install time. If you prefer building from source, pass
// --from-source (needs Go).
//
// Two common layouts for smart-allow:
//   a) Sibling clone next to this project: ../smart-allow
//   b) Git submodule at vendor/smart-allow
{
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway"
  ],

  "containerEnv": {
    "OLLAMA_HOST": "http://host.docker.internal:11434"
  },

  // Option A: sibling directory mount — uncomment these two and comment out Option B.
  // "mounts": [
  //   "source=${localWorkspaceFolder}/../smart-allow,target=/workspaces/smart-allow,type=bind,consistency=cached"
  // ],
  // "postCreateCommand": "bash /workspaces/smart-allow/install.sh --no-path-update",

  // Option B: submodule at vendor/smart-allow
  "postCreateCommand": "bash ${containerWorkspaceFolder}/vendor/smart-allow/install.sh --no-path-update",

  "remoteEnv": {
    "PATH": "${containerEnv:HOME}/.claude/bin:${containerEnv:PATH}"
  }
}
